<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource SkyBlack}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource SkyDarkBlue}" />
        <Setter Property="BarTextColor" Value="{StaticResource StarWhite}" />
    </Style>

    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="TextColor" Value="{StaticResource StarWhite}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="DimLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="AstroButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource TubkalaBlue}" />
        <Setter Property="TextColor" Value="{StaticResource StarWhite}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="NightModeButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource NightRed}" />
        <Setter Property="TextColor" Value="{StaticResource StarWhite}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SkyDarkBlue}" />
        <Setter Property="BorderColor" Value="{StaticResource SkyMidBlue}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>

</ResourceDictionary>
